.texture-overlay {
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
  background-size: 4px 4px;
}
@keyframes blink {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0;
  }
}
.cursor-blink {
  animation: blink 0.8s step-end infinite;
}
@keyframes bgPulse {
  0% {
    opacity: 0.15;
  }
  50% {
    opacity: 0.25;
  }
  100% {
    opacity: 0.15;
  }
}
.bg-pulse-container {
  position: fixed;
  bottom: -30%;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  height: 80%;
  pointer-events: none;
  z-index: -1;
  background: radial-gradient(circle at 50% 100%, var(--color-orange), transparent 75%);
  filter: blur(120px);
  animation: bgPulse 12s ease-in-out infinite;
}
.custom-cursor-active * {
  cursor: none !important;
}
.pixel-cursor {
  position: fixed;
  top: 0;
  left: 0;
  width: 12px;
  height: 12px;
  background: var(--color-orange);
  z-index: 9999;
  pointer-events: none;
  mix-blend-mode: difference;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pixel-cursor-dot {
  width: 4px;
  height: 4px;
  background: var(--color-vanilla);
}
html {
  scroll-behavior: smooth;
}
body {
  background: var(--color-charcoal);
  color: var(--color-vanilla);
  overflow-x: hidden;
}
section {
  scroll-margin-top: 80px;
}
.glitch-hover {
  position: relative;
  display: inline-block;
  transition: transform 0.1s;
}
.glitch-hover:hover {
  transform: skew(-1deg);
}
.glitch-hover:hover::before,
.glitch-hover:hover::after {
  content: attr(data-text);
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  opacity: 0.8;
}
.glitch-hover:hover::before {
  color: #0ff;
  left: 2px;
  top: -1px;
  z-index: -1;
  animation: glitch-anim-subtle 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite;
}
.glitch-hover:hover::after {
  color: #f0f;
  left: -2px;
  top: 1px;
  z-index: -1;
  animation: glitch-anim-subtle 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite reverse;
}
@keyframes glitch-anim-subtle {
  0% {
    transform: translate(0);
  }
  20% {
    transform: translate(-1px, 1px);
  }
  40% {
    transform: translate(-1px, -1px);
  }
  60% {
    transform: translate(1px, 1px);
  }
  80% {
    transform: translate(1px, -1px);
  }
  100% {
    transform: translate(0);
  }
}
